# CareerPilot environment variables
# Copy this file to .env and fill in real values.

# Server
PORT=4000
NODE_ENV=development

# Database
# MongoDB is required for resume, job, and auth features.
MONGO_URI=mongodb://127.0.0.1:27017/careerpilot
# Alternate name supported by the app if you prefer it.
# MONGODB_URI=mongodb://127.0.0.1:27017/careerpilot

# Security
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret

# Frontend / CORS
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://localhost:4000

# Redis
# Set this to your remote Redis provider URL (for example Upstash or Redis Cloud).
REDIS_URL=redis://your-remote-redis-host:6379

# External APIs
JSEARCH_API_KEY=replace-with-your-rapidapi-key
HUGGINGFACE_API_KEY=replace-with-your-hugging-face-api-key

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/oauth/google/callback

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/oauth/github/callback
